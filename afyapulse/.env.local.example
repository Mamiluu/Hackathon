# Forecasting & redistribution microservice (Python/FastAPI). See services/forecasting.
FORECASTING_SERVICE_URL=http://127.0.0.1:8010

# Gemma 4 access via Google AI Studio. Get a key at https://aistudio.google.com/apikey
# If unset, the app falls back to clearly-labeled mock responses so it still runs end-to-end.
GEMINI_API_KEY=
# Model id — confirm the exact Gemma 4 model string available on your key/hackathon
# credentials in Google AI Studio and adjust if needed.
GEMMA_MODEL=gemma-4-27b-it
